# Copy this file to `.env` and fill in the values you need.
# Only the variables required by the stages you actually run need to be set.

# ---- LLM provider (Part C: Fusion & LLM enrichment) ----
# "openai" (GPT-4o, paid) or "gemini" (Gemini Flash, has a free tier)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ---- Speech (Part A) ----
# faster-whisper model size: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=large-v3
# "cpu" or "cuda"
WHISPER_DEVICE=cpu
# Use OpenAI's hosted Whisper API instead of local faster-whisper
USE_OPENAI_WHISPER_API=false
# Injects the active slide's OCR text as Whisper's initial_prompt (helps it
# get jargon/names/acronyms right). Set to false if a persistent on-screen
# watermark/logo is being echoed into the transcript as a hallucinated
# repetition -- see README's Known Limitations for the diagnostic details.
ASR_USE_INITIAL_PROMPT=true
# Caps how long (in seconds) a single merged-same-speaker Transcript segment
# can span before a new segment is started even mid-speaker -- without this,
# one uninterrupted speaker across many diarization turns in a row (a long
# presentation) merges into one huge segment.
TRANSCRIPT_MAX_SEGMENT_DURATION_SEC=120

# Required by pyannote.audio to download pretrained speaker-diarization models
# from the Hugging Face Hub. Create a token at https://huggingface.co/settings/tokens
# and accept the pyannote/speaker-diarization-3.1 model terms.
HUGGINGFACE_TOKEN=

# ---- Vision (Part B) ----
# Sampling rate for scene detection, in frames per second
SCENE_SAMPLE_FPS=2.0
# Pixel-difference threshold (0-1, normalized) above which a frame is a new scene
SCENE_DIFF_THRESHOLD=0.06
# Use GPT-4o vision as an OCR fallback when PaddleOCR yields low-confidence/empty text
OCR_GPT4O_FALLBACK=true

# ---- Vision (Part B) / Zoom speaker identification ----
# Gallery view: detect the active speaker's colored tile border (default
# green -- measured off real footage, hue ~42-50, widened for margin).
# OpenCV hue is 0-179 (half the usual 0-360 degree scale); recalibrate against
# your own footage if your Zoom theme/version highlights a different color,
# e.g. the older yellow border some versions use (roughly hue 20-35).
ZOOM_ACTIVE_SPEAKER_DETECTION=true
ZOOM_BORDER_HUE_MIN=35
ZOOM_BORDER_HUE_MAX=65
ZOOM_BORDER_SAT_MIN=100
ZOOM_BORDER_VAL_MIN=100
# Bridges gaps in a broken/anti-aliased border outline before contour
# detection (pixels); 0 disables.
ZOOM_BORDER_CLOSE_KERNEL_SIZE=5
# The name pill Zoom overlays is anchored bottom-left of the tile, not
# spanning its full width/height -- these crop just that corner.
ZOOM_NAME_LABEL_HEIGHT_FRACTION=0.18
ZOOM_NAME_LABEL_WIDTH_FRACTION=0.65
# Presentation/screen-share mode: fixed top-right speaker badge crop, as a
# fraction of the frame's height/width.
ZOOM_PRESENTATION_BADGE_DETECTION=true
ZOOM_BADGE_TOP_FRACTION=0.22
ZOOM_BADGE_RIGHT_FRACTION=0.22
# Within that badge, the fraction of its height (from the bottom) where
# the name sits below the speaker's video thumbnail.
ZOOM_BADGE_NAME_HEIGHT_FRACTION=0.4

# ---- Speaker Naming (Part C) ----
# A visual speaker event (Zoom active-speaker border / presentation badge)
# only resolves to a speaker if the share of its name's total temporal-
# overlap-weighted evidence pointing at that one speaker clears this
# confidence threshold; otherwise the speaker is labeled "Unknown".
SPEAKER_NAMING_MIN_CONFIDENCE=0.6
# OCR-noise name variants (e.g. "Maria Alvarez" / "Marla Alvarez") within
# this string-similarity ratio of each other are treated as the same person
# before alignment.
SPEAKER_NAMING_NAME_SIMILARITY_THRESHOLD=0.65

# ---- General ----
LOG_LEVEL=INFO
